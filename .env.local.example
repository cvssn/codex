# clerk auth
# create app at https://dashboard.clerk.com -> copy keys here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# clerk redirect urls (paths, not full urls)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# vercel blob (photographs storage)
# create store at vercel dashboard -> storage -> blob -> copy token here
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
